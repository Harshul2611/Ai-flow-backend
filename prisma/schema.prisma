generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

model AiFlow {
  id        String    @id @default(auto()) @map("_id") @db.ObjectId
  prompt    String
  response  String
  createdAt DateTime  @default(now())
  updatedAt DateTime?
}
